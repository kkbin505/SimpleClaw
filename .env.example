# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here

# Discord 配置
DISCORD_TOKEN=your_discord_bot_token_here

# 日程助理配置
ASSISTANT_NAME=Cortanal
TIMEZONE=America/Los_Angeles
POLL_INTERVAL_SECONDS=60

# 用户映射配置 (名字:DiscordID,名字:DiscordID)
USER_MAP=Jack:YOUR_DISCORD_ID,Zhen:YOUR_DISCORD_ID

# 文档过滤关键词 (英文逗号分隔)
DOC_TITLE_KEYWORDS=Minutes,Meeting,Weekly,会议纪要
